{
  "name": "nakora",
  "version": "0.1.0",
  "description": "System-wide DNS Security Shield — on-device, privacy-first, CISA PDNS-inspired",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "node scripts/build.js && vite build && node scripts/validate-csp.js",
    "dist": "npm run build && electron-builder",
    "lint": "eslint src",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "electron-store": "^8.2.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.27.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.9",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "dev.nakora.prototype",
    "productName": "nakora",
    "asar": true,
    "asarUnpack": ["**/better-sqlite3/**"],
    "directories": { "output": "dist-electron" },
    "files": ["src/main/**", "src/preload/**", "dist/**", "data/**", "assets/**"],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icons/icon.ico"
    }
  },
  "engines": { "node": ">=20.19.0" }
}
